# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Cloudflare opennext output
/.open-next/

# wrangler
.wrangler/
.dev.vars

# misc
.DS_Store
*.pem

# brand exploration artifacts (kept local, not shipped)
/public/logo-concepts/

# TWA build artifacts and signing key (kept local, never committed)
/twa/android.keystore
/twa/.keystore-password.local
/twa/*.aab
/twa/*.apk
/twa/build/
/twa/.gradle/
/twa/app/
/twa/gradle/
/twa/local.properties
/twa/store_icon.png
/twa/gradlew
/twa/gradlew.bat
/twa/gradle.properties
/twa/build.gradle
/twa/settings.gradle
/twa/node_modules/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
